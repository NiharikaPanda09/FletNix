# =============================================================================
# FletNIx Monorepo .gitignore
# Covers: Angular Frontend, Node.js/Express Backend, Render Deployment
# =============================================================================

# =============================================================================
# Node / npm (root, backend, frontend)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Environment & Secrets — NEVER commit these
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key

# =============================================================================
# Backend (Node.js / Express / MongoDB)
# =============================================================================
backend/node_modules/
backend/.env
backend/.env.*
backend/logs/
backend/*.log

# =============================================================================
# Frontend (Angular)
# =============================================================================
frontend/node_modules/
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/

# Angular cache
frontend/.angular/

# Angular test coverage
frontend/coverage/
frontend/.nyc_output/

# =============================================================================
# Build / Dist outputs
# =============================================================================
dist/
build/
out/
.output/
.vercel/
.netlify/

# =============================================================================
# IDEs & Editors
# =============================================================================
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# VSCode (keep shared settings, ignore personal/machine-specific)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/

# =============================================================================
# OS & System files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Testing
# =============================================================================
/coverage
__screenshots__/
test-results/
playwright-report/
e2e/node_modules/

# =============================================================================
# Miscellaneous
# =============================================================================
.sass-cache/
.connect.lock
/libpeerconnection.log
testem.log
/typings
*.seed
*.gz
*.tgz

# Render deploy artifacts
render.yaml.local
